# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional — Baton event tracking (graceful fallback to in-memory without it)
# Local: docker compose --profile baton up, then set BATON_URL=http://localhost:3004
BATON_URL=
BATON_ACTOR_ID=fulcrum

# Injected automatically by Render when using render.yaml
# REDIS_URL=redis://...
